<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>공모주 대시보드</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0e0f11;
      --surface:   #16181c;
      --surface2:  #1e2027;
      --border:    #2a2d35;
      --text:      #e4e6ed;
      --muted:     #6b7280;
      --green:     #4ade80;
      --red:       #f87171;
      --amber:     #fbbf24;
      --blue:      #60a5fa;
      --purple:    #a78bfa;
      --pink:      #f472b6;
    }

    body {
      font-family: 'Noto Sans KR', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 24px 16px 120px;
    }

    .mono { font-family: 'DM Mono', monospace; }

    /* ── WRAPPER ── */
    .wrapper {
      max-width: 860px;
      margin: 0 auto;
    }

    /* ── HEADER ── */
    .header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 28px;
      flex-wrap: wrap;
    }
    .header-left h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #fff;
    }
    .header-left .subtitle {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 4px;
      font-size: 13px;
      color: var(--muted);
    }
    .header-left .subtitle .month {
      color: var(--green);
      font-weight: 600;
    }
    .header-left .subtitle .last-updated {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
    }
    .header-right {
      display: flex;
      gap: 6px;
      flex-shrink: 0;
    }
    .toggle-btn {
      padding: 7px 16px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--muted);
      font-size: 13px;
      font-family: 'Noto Sans KR', sans-serif;
      cursor: pointer;
      transition: all .15s;
    }
    .toggle-btn.active {
      background: var(--green);
      border-color: var(--green);
      color: #0e0f11;
      font-weight: 600;
    }
    .toggle-btn:not(.active):hover {
      border-color: var(--green);
      color: var(--green);
    }

    /* ── STAT CARDS ── */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 24px;
    }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
    }
    .stat-card .label {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 8px;
      letter-spacing: 0.3px;
    }
    .stat-card .value {
      font-family: 'DM Mono', monospace;
      font-size: 26px;
      font-weight: 500;
      color: #fff;
      line-height: 1;
    }
    .stat-card .value span {
      font-size: 13px;
      color: var(--muted);
      font-weight: 400;
    }
    .stat-card.highlight .value { color: var(--green); }

    /* ── FILTER ── */
    .controls {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .filter-btn {
      padding: 6px 14px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      font-size: 13px;
      font-family: 'Noto Sans KR', sans-serif;
      cursor: pointer;
      transition: all .15s;
    }
    .filter-btn.active {
      border-color: var(--green);
      color: var(--green);
      background: rgba(74, 222, 128, .08);
    }
    .filter-btn:not(.active):hover {
      border-color: #4b5563;
      color: var(--text);
    }

    /* ── EVENT TYPE PANEL ── */
    .event-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 18px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .event-panel .panel-label {
      font-size: 12px;
      color: var(--muted);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .event-checkboxes {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }
    .event-check-item {
      display: flex;
      align-items: center;
      gap: 7px;
      cursor: pointer;
      user-select: none;
    }
    .event-check-item input[type="checkbox"] { display: none; }
    .check-box {
      width: 18px;
      height: 18px;
      border-radius: 5px;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .15s;
      flex-shrink: 0;
    }
    .event-check-item input:checked + .check-box {
      background: var(--green);
      border-color: var(--green);
    }
    .event-check-item input:checked + .check-box::after {
      content: '';
      display: block;
      width: 5px;
      height: 9px;
      border: 2px solid #0e0f11;
      border-top: none;
      border-left: none;
      transform: rotate(45deg) translateY(-1px);
    }
    .check-label {
      font-size: 13px;
      color: var(--muted);
      transition: color .15s;
    }
    .event-check-item input:checked ~ .check-label { color: var(--text); }

    @keyframes shake {
      0%,100% { transform: translateX(0); }
      20%      { transform: translateX(-4px); }
      40%      { transform: translateX(4px); }
      60%      { transform: translateX(-3px); }
      80%      { transform: translateX(3px); }
    }
    .shake { animation: shake .35s ease; }

    /* ── CARD LIST ── */
    .card-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .ipo-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid transparent;
      border-radius: 12px;
      padding: 16px 18px;
      display: grid;
      grid-template-columns: 24px 1fr auto;
      align-items: center;
      gap: 14px;
      cursor: pointer;
      transition: border-color .15s, background .15s, opacity .2s;
      position: relative;
    }
    .ipo-card:hover { border-color: #2a2d35; background: #1a1c21; }
    .ipo-card.selected {
      border-left-color: var(--green);
      background: rgba(74, 222, 128, .04);
    }
    .ipo-card.registered { opacity: .45; pointer-events: none; }
    .ipo-card.past { opacity: .5; }
    .ipo-card.upcoming { background: rgba(255, 255, 255, 0.06); border-color: rgba(255,255,255,0.12); }

    /* checkbox col */
    .card-check {
      width: 20px;
      height: 20px;
      border-radius: 6px;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all .15s;
    }
    .ipo-card.selected .card-check {
      background: var(--green);
      border-color: var(--green);
    }
    .ipo-card.selected .card-check::after {
      content: '';
      display: block;
      width: 5px;
      height: 9px;
      border: 2px solid #0e0f11;
      border-top: none;
      border-left: none;
      transform: rotate(45deg) translateY(-1px);
    }

    /* main info */
    .card-main { min-width: 0; }
    .card-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }
    .card-name {
      font-size: 15px;
      font-weight: 600;
      color: #fff;
      white-space: nowrap;
    }
    .badge {
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      flex-shrink: 0;
    }
    .badge-bio   { background: rgba(167,139,250,.15); color: var(--purple); }
    .badge-med   { background: rgba(96,165,250,.15);  color: var(--blue); }
    .badge-fin   { background: rgba(251,191,36,.15);  color: var(--amber); }
    .badge-etc   { background: rgba(107,114,128,.15); color: var(--muted); }
    .badge-hot   { background: rgba(248,113,113,.18); color: var(--red); letter-spacing: .5px; }
    .badge-reg   { background: rgba(74,222,128,.12);  color: var(--green); }

    .card-meta {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      font-size: 12px;
      color: var(--muted);
    }
    .card-meta .item { display: flex; gap: 4px; align-items: center; }
    .card-meta .val  { font-family: 'DM Mono', monospace; color: var(--text); }
    .card-meta .rate-red    { color: var(--red); }
    .card-meta .rate-amber  { color: var(--amber); }
    .card-meta .rate-normal { color: var(--text); }

    /* dates col */
    .card-dates {
      text-align: right;
      flex-shrink: 0;
    }
    .card-dates .date-row {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 6px;
      margin-bottom: 5px;
      font-size: 12px;
    }
    .card-dates .date-row:last-child { margin-bottom: 0; }
    .date-label { color: var(--muted); }
    .date-val   { font-family: 'DM Mono', monospace; color: var(--text); }

    /* ── FOOTER ── */
    .footer-bar {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: rgba(14,15,17,.92);
      backdrop-filter: blur(12px);
      border-top: 1px solid var(--border);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      z-index: 100;
    }
    .footer-inner {
      max-width: 860px;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .footer-info {
      font-size: 13px;
      color: var(--muted);
    }
    .footer-info strong { color: var(--green); font-family: 'DM Mono', monospace; }
    .register-btn {
      padding: 11px 28px;
      border-radius: 10px;
      border: none;
      background: var(--green);
      color: #0e0f11;
      font-size: 14px;
      font-weight: 700;
      font-family: 'Noto Sans KR', sans-serif;
      cursor: pointer;
      transition: all .15s;
      white-space: nowrap;
    }
    .register-btn:disabled {
      background: var(--surface2);
      color: var(--muted);
      cursor: not-allowed;
    }
    .register-btn:not(:disabled):hover {
      background: #86efac;
      transform: translateY(-1px);
    }
    .register-btn:not(:disabled):active { transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 680px) {
      .stats { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 540px) {
      .stats { grid-template-columns: 1fr 1fr; }
      .ipo-card { grid-template-columns: 24px 1fr; }
      .card-dates { display: none; }
      .card-meta { gap: 10px; }
    }
    @media (max-width: 400px) {
      .stats { grid-template-columns: 1fr; }
    }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center;
      padding: 60px 0;
      color: var(--muted);
    }
    .empty-state .icon { font-size: 36px; margin-bottom: 12px; }
    .empty-state p { font-size: 14px; }

    /* ── TOAST ── */
    .toast {
      position: fixed;
      bottom: 80px;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 20px;
      font-size: 13px;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 8px;
      z-index: 200;
      opacity: 0;
      transition: opacity .25s, transform .25s;
      pointer-events: none;
      white-space: nowrap;
    }
    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    .toast.success { border-color: var(--green); }
    .toast.error   { border-color: var(--red); }

    /* ── REGISTER BTN LOADING ── */
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid rgba(0,0,0,.3);
      border-top-color: #0e0f11;
      border-radius: 50%;
      animation: spin .7s linear infinite;
      vertical-align: middle;
      margin-right: 6px;
    }
  </style>
</head>
<body>

<div class="wrapper">

  <!-- HEADER -->
  <header class="header">
    <div class="header-left">
      <h1>공모주 대시보드</h1>
      <div class="subtitle">
        <span class="month" id="currentMonth"></span>
        <span class="last-updated" id="lastUpdated"></span>
      </div>
    </div>
    <div class="header-right">
      <button class="toggle-btn active" id="btnWeek"  onclick="setView('week')">이번 주</button>
      <button class="toggle-btn"        id="btnMonth" onclick="setView('month')">이번 달</button>
    </div>
  </header>

  <!-- STATS -->
  <div class="stats">
    <div class="stat-card">
      <div class="label">전체 종목</div>
      <div class="value mono" id="statTotal">0<span>개</span></div>
    </div>
    <div class="stat-card highlight">
      <div class="label">선택된 종목</div>
      <div class="value mono" id="statSelected">0<span>개</span></div>
    </div>
    <div class="stat-card">
      <div class="label">등록 완료</div>
      <div class="value mono" id="statRegistered">0<span>개</span></div>
    </div>
    <div class="stat-card">
      <div class="label">평균 경쟁률</div>
      <div class="value mono" id="statAvgRate">—<span>:1</span></div>
    </div>
  </div>

  <!-- FILTER -->
  <div class="controls">
    <button class="filter-btn active" data-filter="all"    onclick="setFilter(this)">전체</button>
    <button class="filter-btn"        data-filter="bio"    onclick="setFilter(this)">바이오</button>
    <button class="filter-btn"        data-filter="med"    onclick="setFilter(this)">의료기기</button>
    <button class="filter-btn"        data-filter="fin"    onclick="setFilter(this)">핀테크</button>
    <button class="filter-btn"        data-filter="rate"   onclick="setFilter(this)">경쟁률 높은순</button>
  </div>

  <!-- EVENT TYPE PANEL -->
  <div class="event-panel">
    <span class="panel-label">캘린더 등록 유형</span>
    <div class="event-checkboxes" id="eventCheckboxes">
      <label class="event-check-item">
        <input type="checkbox" id="ev_sub_start" value="sub_start" checked onchange="toggleEvent(this)" />
        <span class="check-box"></span>
        <span class="check-label">청약 시작일</span>
      </label>
      <label class="event-check-item">
        <input type="checkbox" id="ev_sub_end" value="sub_end" checked onchange="toggleEvent(this)" />
        <span class="check-box"></span>
        <span class="check-label">청약 종료일</span>
      </label>
      <label class="event-check-item">
        <input type="checkbox" id="ev_list_date" value="list_date" checked onchange="toggleEvent(this)" />
        <span class="check-box"></span>
        <span class="check-label">상장일</span>
      </label>
      <label class="event-check-item">
        <input type="checkbox" id="ev_refund_date" value="refund_date" onchange="toggleEvent(this)" />
        <span class="check-box"></span>
        <span class="check-label">환불일</span>
      </label>
    </div>
  </div>

  <!-- CARD LIST -->
  <div class="card-list" id="cardList"></div>

</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- FOOTER -->
<div class="footer-bar">
  <div class="footer-inner">
    <div class="footer-info">
      <strong id="footerCount">0</strong>개 종목 선택됨
    </div>
    <button class="register-btn" id="registerBtn" disabled onclick="handleRegister()">
      📅 Google Calendar에 등록
    </button>
  </div>
</div>

<!-- Google API scripts (lazy-loaded on demand) -->
<script>
// ──────────────────────────────────────────
// Google Calendar 연동 설정 방법
// 1. https://console.cloud.google.com 접속
// 2. 새 프로젝트 생성
// 3. Google Calendar API 활성화
// 4. OAuth 2.0 클라이언트 ID 생성 (웹 애플리케이션)
// 5. 승인된 JavaScript 원본에 아래 추가:
//    - http://localhost (로컬 파일 실행 시)
//    - file:// (직접 파일 열기 시)
//    - https://ttruee.github.io (GitHub Pages 배포 시)
// 6. 아래 CLIENT_ID에 발급받은 클라이언트 ID 입력
// ──────────────────────────────────────────
const CLIENT_ID = '416628876905-btnptt8qjkd71o4a4i5mlg67m1gg4c2s.apps.googleusercontent.com';
const SCOPES = 'https://www.googleapis.com/auth/calendar.events';
</script>
<script>
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// COWORK_UPDATE_START — 이 아래 데이터를 매달 업데이트
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
const IPOS = [
  { id:1, name:"아이엠바이오로직스", sector:"bio", market:"코스닥",
    price:"26,000원", sub_start:"03.11", sub_end:"03.12",
    refund_date:"03.16", list_date:"03.20", comp_rate:839.23,
    lead_manager:"한국투자증권", selected:false, registered:false },
  { id:2, name:"메쥬", sector:"med", market:"코스닥",
    price:"21,600원", sub_start:"03.16", sub_end:"03.17",
    refund_date:"03.19", list_date:"03.26", comp_rate:1108.93,
    lead_manager:"신한투자증권", selected:false, registered:false },
  { id:3, name:"한패스", sector:"fin", market:"코스닥",
    price:"19,000원", sub_start:"03.16", sub_end:"03.17",
    refund_date:"03.19", list_date:"03.25", comp_rate:1172.59,
    lead_manager:"한국투자증권", selected:false, registered:false },
  { id:4, name:"리센스메디컬", sector:"med", market:"코스닥",
    price:"11,000원", sub_start:"03.19", sub_end:"03.20",
    refund_date:"03.24", list_date:"03.31", comp_rate:1352.63,
    lead_manager:"KB증권", selected:false, registered:false },
  { id:5, name:"인벤테라", sector:"bio", market:"코스닥",
    price:"16,600원", sub_start:"03.23", sub_end:"03.24",
    refund_date:"03.27", list_date:"04.02", comp_rate:1328.82,
    lead_manager:"NH투자증권", selected:false, registered:false },
  { id:6, name:"코스모로보틱스", sector:"etc", market:"코스닥",
    price:"5,300~6,000원", sub_start:"04.09", sub_end:"04.10",
    refund_date:"미정", list_date:"미정", comp_rate:null,
    lead_manager:"미정", selected:false, registered:false },
  { id:7, name:"채비", sector:"etc", market:"코스닥",
    price:"12,300~15,300원", sub_start:"04.20", sub_end:"04.21",
    refund_date:"미정", list_date:"미정", comp_rate:null,
    lead_manager:"KB증권", selected:false, registered:false },
];
const LAST_UPDATED = "2026-03-23";
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// COWORK_UPDATE_END
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ── STATE ──
let currentFilter = 'all';
let currentView   = 'week';

const SECTOR_LABEL = { bio:'바이오', med:'의료기기', fin:'핀테크', etc:'기타' };
const SECTOR_CLASS = { bio:'badge-bio', med:'badge-med', fin:'badge-fin', etc:'badge-etc' };

// ── INIT ──
function init() {
  // 헤더 월 표시
  const now = new Date();
  document.getElementById('currentMonth').textContent =
    `${now.getFullYear()}년 ${now.getMonth()+1}월`;

  // 마지막 업데이트
  const lastUp = localStorage.getItem('ipo_last_updated') || LAST_UPDATED;
  document.getElementById('lastUpdated').textContent = `업데이트: ${lastUp}`;
  localStorage.setItem('ipo_last_updated', LAST_UPDATED);

  // 등록 이력 복원 (월이 바뀌면 초기화)
  const savedMonth = localStorage.getItem('ipo_saved_month');
  const thisMonth  = `${now.getFullYear()}-${now.getMonth()+1}`;
  if (savedMonth !== thisMonth) {
    localStorage.removeItem('ipo_registered');
    localStorage.setItem('ipo_saved_month', thisMonth);
  }
  const registered = JSON.parse(localStorage.getItem('ipo_registered') || '[]');
  IPOS.forEach(ipo => { if (registered.includes(ipo.id)) ipo.registered = true; });

  // 이벤트 유형 복원
  const savedEvents = JSON.parse(localStorage.getItem('ipo_active_events') || 'null');
  if (savedEvents && savedEvents.length > 0) {
    document.querySelectorAll('#eventCheckboxes input').forEach(cb => {
      cb.checked = savedEvents.includes(cb.value);
    });
  } else {
    // 첫 방문 시 기본 선택 상태를 localStorage에 저장
    const defaultActive = [...document.querySelectorAll('#eventCheckboxes input:checked')].map(c => c.value);
    localStorage.setItem('ipo_active_events', JSON.stringify(defaultActive));
  }

  render();
}

// ── HELPERS ──
function isPast(mmdd) {
  const now = new Date();
  const [m, d] = mmdd.split('.').map(Number);
  const target = new Date(now.getFullYear(), m - 1, d);
  const today  = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  return target < today;
}

function isThisWeek(mmdd) {
  const now   = new Date();
  const [m,d] = mmdd.split('.').map(Number);
  const date  = new Date(now.getFullYear(), m - 1, d);
  const mon   = new Date(now); mon.setDate(now.getDate() - ((now.getDay()+6)%7));
  mon.setHours(0,0,0,0);
  const sun   = new Date(mon); sun.setDate(mon.getDate() + 6); sun.setHours(23,59,59,999);
  return date >= mon && date <= sun;
}

function rateClass(rate) {
  if (!rate) return '';
  if (rate >= 1000) return 'rate-red';
  if (rate >= 500)  return 'rate-amber';
  return 'rate-normal';
}

// ── FILTER ──
function getFiltered() {
  let list = [...IPOS];

  if (currentFilter === 'bio')  list = list.filter(i => i.sector === 'bio');
  if (currentFilter === 'med')  list = list.filter(i => i.sector === 'med');
  if (currentFilter === 'fin')  list = list.filter(i => i.sector === 'fin');
  if (currentFilter === 'rate') {
    list.sort((a,b) => {
      if (a.comp_rate == null && b.comp_rate == null) return 0;
      if (a.comp_rate == null) return 1;
      if (b.comp_rate == null) return -1;
      return b.comp_rate - a.comp_rate;
    });
  }

  if (currentView === 'week') {
    list = list.filter(i =>
      isThisWeek(i.sub_start) || isThisWeek(i.sub_end) ||
      isThisWeek(i.list_date) || isThisWeek(i.refund_date)
    );
  }

  return list;
}

// ── RENDER ──
function render() {
  const list = getFiltered();
  const container = document.getElementById('cardList');

  if (list.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <div class="icon">📭</div>
        <p>해당 기간에 공모주 일정이 없습니다</p>
      </div>`;
  } else {
    container.innerHTML = list.map(ipo => buildCard(ipo)).join('');
  }

  updateStats();
}

function buildCard(ipo) {
  const sectorKey   = SECTOR_LABEL[ipo.sector] ? ipo.sector : 'etc';
  const sectorLabel = SECTOR_LABEL[sectorKey];
  const sectorCls   = SECTOR_CLASS[sectorKey];
  const hotBadge    = ipo.comp_rate >= 1000
    ? `<span class="badge badge-hot">🔥 HOT</span>` : '';
  const regBadge    = ipo.registered
    ? `<span class="badge badge-reg">✓ 등록됨</span>` : '';

  const rateText = ipo.comp_rate
    ? `<span class="val ${rateClass(ipo.comp_rate)}">${ipo.comp_rate.toLocaleString()}:1</span>`
    : `<span class="val" style="color:var(--muted)">미정</span>`;

  const past = isPast(ipo.sub_end);
  const cls  = [
    'ipo-card',
    ipo.selected   ? 'selected'   : '',
    ipo.registered ? 'registered' : '',
    past && !ipo.registered ? 'past' : '',
    !past && !ipo.registered ? 'upcoming' : ''
  ].filter(Boolean).join(' ');

  return `
  <div class="${cls}" id="card-${ipo.id}" onclick="toggleCard(${ipo.id})">
    <div class="card-check"></div>
    <div class="card-main">
      <div class="card-top">
        <span class="card-name">${ipo.name}</span>
        <span class="badge ${sectorCls}">${sectorLabel}</span>
        ${hotBadge}
        ${regBadge}
      </div>
      <div class="card-meta">
        <span class="item"><span class="label">시장</span><span class="val">${ipo.market}</span></span>
        <span class="item"><span class="label">공모가</span><span class="val">${ipo.price}</span></span>
        <span class="item"><span class="label">경쟁률</span>${rateText}</span>
        <span class="item"><span class="label">주관사</span><span class="val">${ipo.lead_manager}</span></span>
      </div>
    </div>
    <div class="card-dates">
      <div class="date-row">
        <span class="date-label">청약</span>
        <span class="date-val">${ipo.sub_start} ~ ${ipo.sub_end}</span>
      </div>
      <div class="date-row">
        <span class="date-label">환불</span>
        <span class="date-val">${ipo.refund_date}</span>
      </div>
      <div class="date-row">
        <span class="date-label">상장</span>
        <span class="date-val">${ipo.list_date}</span>
      </div>
    </div>
  </div>`;
}

// ── STATS ──
function updateStats() {
  const total      = IPOS.length;
  const selected   = IPOS.filter(i => i.selected).length;
  const registered = IPOS.filter(i => i.registered).length;
  const rateList   = IPOS.filter(i => i.comp_rate != null).map(i => i.comp_rate);
  const avgRate    = rateList.length
    ? Math.round(rateList.reduce((a,b) => a+b, 0) / rateList.length)
    : null;

  document.getElementById('statTotal').innerHTML      = `${total}<span>개</span>`;
  document.getElementById('statSelected').innerHTML   = `${selected}<span>개</span>`;
  document.getElementById('statRegistered').innerHTML = `${registered}<span>개</span>`;
  document.getElementById('statAvgRate').innerHTML    = avgRate
    ? `${avgRate.toLocaleString()}<span>:1</span>` : `—<span>:1</span>`;

  document.getElementById('footerCount').textContent = selected;
  document.getElementById('registerBtn').disabled    = selected === 0;
}

// ── INTERACTIONS ──
function toggleCard(id) {
  const ipo = IPOS.find(i => i.id === id);
  if (!ipo || ipo.registered) return;
  ipo.selected = !ipo.selected;
  render();
}

function setFilter(btn) {
  currentFilter = btn.dataset.filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function setView(view) {
  currentView = view;
  document.getElementById('btnWeek').classList.toggle('active',  view === 'week');
  document.getElementById('btnMonth').classList.toggle('active', view === 'month');
  render();
}

function toggleEvent(cb) {
  const checked = document.querySelectorAll('#eventCheckboxes input:checked');
  if (checked.length === 0) {
    // 최소 1개 강제 — 해제 취소 + 흔들림
    cb.checked = true;
    cb.closest('.event-check-item').classList.remove('shake');
    void cb.closest('.event-check-item').offsetWidth; // reflow
    cb.closest('.event-check-item').classList.add('shake');
    return;
  }
  // 저장
  const active = [...document.querySelectorAll('#eventCheckboxes input:checked')].map(c => c.value);
  localStorage.setItem('ipo_active_events', JSON.stringify(active));
}

// ── GOOGLE CALENDAR INTEGRATION ──

const EVENT_LABELS = {
  sub_start:   '청약 시작',
  sub_end:     '청약 종료',
  list_date:   '상장일',
  refund_date: '환불일'
};

// MM.DD → YYYY-MM-DD (현재 연도 기준)
function toIsoDate(mmdd) {
  const [m, d] = mmdd.split('.').map(Number);
  const year   = new Date().getFullYear();
  return `${year}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
}

function buildDescription(ipo) {
  const rateStr = ipo.comp_rate ? `${ipo.comp_rate.toLocaleString()}:1` : '미정';
  return [
    `시장: ${ipo.market}`,
    `공모가: ${ipo.price}`,
    `기관 경쟁률: ${rateStr}`,
    `주관사: ${ipo.lead_manager}`,
    `청약: ${ipo.sub_start} ~ ${ipo.sub_end}`,
    `상장: ${ipo.list_date}`
  ].join('\n');
}

function buildEvents(selectedIpos, activeEventTypes) {
  const events = [];
  const DATE_FIELD = {
    sub_start:   'sub_start',
    sub_end:     'sub_end',
    list_date:   'list_date',
    refund_date: 'refund_date'
  };
  selectedIpos.forEach(ipo => {
    activeEventTypes.forEach(type => {
      const dateStr = ipo[DATE_FIELD[type]];
      if (!dateStr) return;
      events.push({
        summary: `[공모주] ${ipo.name} ${EVENT_LABELS[type]}`,
        description: buildDescription(ipo),
        start: { date: toIsoDate(dateStr) },
        end:   { date: toIsoDate(dateStr) }
      });
    });
  });
  return events;
}

// ── TOAST ──
let toastTimer = null;
function showToast(msg, type = 'success') {
  const el = document.getElementById('toast');
  el.textContent = type === 'success' ? '✓ ' + msg : '✕ ' + msg;
  el.className   = `toast ${type} show`;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.classList.remove('show'); }, 2500);
}

// ── REGISTER BTN STATE ──
function setRegisterLoading(on) {
  const btn = document.getElementById('registerBtn');
  if (on) {
    btn.disabled   = true;
    btn.innerHTML  = '<span class="spinner"></span>등록 중...';
  } else {
    const cnt = IPOS.filter(i => i.selected).length;
    btn.disabled  = cnt === 0;
    btn.innerHTML = '📅 Google Calendar에 등록';
  }
}

// ── MARK REGISTERED ──
function markRegistered(ids) {
  ids.forEach(id => {
    const ipo = IPOS.find(i => i.id === id);
    if (ipo) { ipo.registered = true; ipo.selected = false; }
  });
  const allRegistered = IPOS.filter(i => i.registered).map(i => i.id);
  localStorage.setItem('ipo_registered', JSON.stringify(allRegistered));
  render();
}

// ── GOOGLE API LOADER ──
let gapiReady = false;
let gisReady  = false;
let tokenClient = null;

function loadGoogleScripts() {
  return new Promise((resolve, reject) => {
    let loaded = 0;
    const check = () => { if (++loaded === 2) resolve(); };

    if (!document.getElementById('gapi-script')) {
      const s = document.createElement('script');
      s.id  = 'gapi-script';
      s.src = 'https://apis.google.com/js/api.js';
      s.onload  = () => { gapi.load('client', () => { gapiReady = true; check(); }); };
      s.onerror = reject;
      document.head.appendChild(s);
    } else { check(); }

    if (!document.getElementById('gis-script')) {
      const s = document.createElement('script');
      s.id  = 'gis-script';
      s.src = 'https://accounts.google.com/gsi/client';
      s.onload  = () => { gisReady = true; check(); };
      s.onerror = reject;
      document.head.appendChild(s);
    } else { check(); }
  });
}

async function initGapi() {
  await gapi.client.init({});
  await gapi.client.load('https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest');
}

function getStoredToken() {
  try {
    const t = JSON.parse(localStorage.getItem('gcal_token') || 'null');
    if (!t) return null;
    if (Date.now() > t.expires_at - 60000) { localStorage.removeItem('gcal_token'); return null; }
    return t.access_token;
  } catch { return null; }
}

function storeToken(tokenResponse) {
  const expires_at = Date.now() + (tokenResponse.expires_in || 3600) * 1000;
  localStorage.setItem('gcal_token', JSON.stringify({
    access_token: tokenResponse.access_token,
    expires_at
  }));
}

function requestToken() {
  return new Promise((resolve, reject) => {
    if (!tokenClient) {
      tokenClient = google.accounts.oauth2.initTokenClient({
        client_id: CLIENT_ID,
        scope: SCOPES,
        callback: (resp) => {
          if (resp.error) { reject(new Error(resp.error)); return; }
          storeToken(resp);
          resolve(resp.access_token);
        }
      });
    }
    tokenClient.requestAccessToken({ prompt: '' });
  });
}

async function getAccessToken() {
  const stored = getStoredToken();
  if (stored) return stored;
  return requestToken();
}

// ── CREATE EVENTS VIA API ──
async function createCalendarEvents(events, accessToken) {
  gapi.client.setToken({ access_token: accessToken });
  const results = await Promise.allSettled(
    events.map(ev =>
      gapi.client.calendar.events.insert({ calendarId: 'primary', resource: ev })
    )
  );
  const failed = results.filter(r => r.status === 'rejected');
  return { total: events.length, failed: failed.length };
}

// ── MAIN HANDLER ──
async function handleRegister() {
  if (CLIENT_ID === 'YOUR_GOOGLE_CLIENT_ID_HERE') {
    showToast('CLIENT_ID를 설정해주세요. 파일 상단 주석을 참고하세요.', 'error');
    return;
  }

  const selectedIpos = IPOS.filter(i => i.selected && !i.registered);
  if (selectedIpos.length === 0) return;

  const activeEventTypes = [...document.querySelectorAll('#eventCheckboxes input:checked')]
    .map(c => c.value);

  const events = buildEvents(selectedIpos, activeEventTypes);
  if (events.length === 0) return;

  setRegisterLoading(true);

  try {
    await loadGoogleScripts();
    if (!gapiReady) await initGapi();
    else if (!gapi.client.calendar) await initGapi();

    const token = await getAccessToken();
    const { total, failed } = await createCalendarEvents(events, token);

    if (failed === 0) {
      markRegistered(selectedIpos.map(i => i.id));
      showToast(`${total}개 이벤트를 Google Calendar에 등록했습니다.`, 'success');
    } else if (failed < total) {
      markRegistered(selectedIpos.map(i => i.id));
      showToast(`일부 등록 실패 (${total - failed}/${total}건 성공)`, 'error');
    } else {
      showToast('등록에 실패했습니다. 다시 시도해주세요.', 'error');
    }
  } catch (err) {
    console.error('Calendar registration error:', err);
    const msg = err.message?.includes('popup') ? '팝업이 차단되었습니다. 팝업을 허용해주세요.'
              : err.message?.includes('access_denied') ? 'Google 로그인이 취소되었습니다.'
              : '등록 중 오류가 발생했습니다.';
    showToast(msg, 'error');
  } finally {
    setRegisterLoading(false);
  }
}

// ── BOOT ──
init();
</script>
</body>
</html>
